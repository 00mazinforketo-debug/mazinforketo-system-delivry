{
  "name": "mazin-for-keto",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "wrangler dev --local --port 8787",
    "dev:full": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "build": "tsc -b && tsc -p tsconfig.worker.json && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cf:login": "wrangler login",
    "cf:deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply restaurant_ops --local",
    "db:migrate:remote": "wrangler d1 migrations apply restaurant_ops --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^3.10.0",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "firebase": "^12.11.0",
    "hono": "^4.12.9",
    "idb": "^8.0.3",
    "lucide-react": "^0.542.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.66.0",
    "react-router-dom": "^6.30.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wrangler": "^4.76.0"
  }
}
